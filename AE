  <script>
  // ═══ STAGE DATA ═══════════════════
  var stages = [
    { num:'01', name:'Discovery', weeks:'Week 1–2',
      goal:'Understand the real pain — not what they say first, but what keeps them up at night.',
      actions:['Open: "Walk me through what happens when an employee needs to buy something..."',
               'Ask: "Where does the process break down most?" — stay silent and let them talk',
               'Ask: "If nothing changes in 12 months, what does that mean for your team?"',
               'Close by summarizing their pain in their own words — show you listened'],
      exits:['Top 3 pain points identified in Shilpan\'s own language',
             'Initial stakeholder map drafted',
             'Next meeting booked before hanging up'] },
    { num:'02', name:'Qualification', weeks:'Week 2–3', ... },
    { num:'03', name:'Demo + Business Case', weeks:'Week 3–5', ... },
    { num:'04', name:'Stakeholder Alignment', weeks:'Week 5–8', ... },
    { num:'05', name:'Pilot / POV', weeks:'Week 6–10', ... },
    { num:'06', name:'Commercial', weeks:'Week 10–12', ... },
    { num:'07', name:'Legal & Sign', weeks:'Week 12–14', ... },
    { num:'08', name:'Closed-Won', weeks:'Day 90–100', ... }
  ];

  function selTab(i) {
    var tabs = document.getElementsByClassName('tab');
    for (var t = 0; t < tabs.length; t++) {
      tabs[t].classList.toggle('active', t === i);
    }
    var s = stages[i];
    var h = '';
    h += '<div class="sp-goal-lbl">Stage Goal</div>';
    h += '<div class="sp-goal">' + s.goal + '</div>';
    h += '<div class="sp-cols">';
    h += '<div class="sp-col"><h5>Key Actions</h5><ul>';
    for (var a = 0; a < s.actions.length; a++) { h += '<li>' + s.actions[a] + '</li>'; }
    h += '</ul></div>';
    h += '<div class="sp-col"><h5>Exit Criteria</h5><ul>';
    for (var e = 0; e < s.exits.length; e++) { h += '<li>' + s.exits[e] + '</li>'; }
    h += '</ul></div></div>';
    document.getElementById('panelWrap').innerHTML = h;
  }
  selTab(0);

  // ═══ CHARTS ═══════════════════════
  window.addEventListener('load', function() {
    var attempts = 0;
    function tryInit() {
      if (typeof Chart === 'undefined') {
        attempts++;
        if (attempts < 20) setTimeout(tryInit, 300);
        return;
      }
      Chart.defaults.font.family = 'Inter';
      Chart.defaults.color = '#8892B0';

      var tooltipOpts = {
        backgroundColor: '#0B0F24',
        borderColor: 'rgba(74,143,255,0.2)',
        borderWidth: 1,
        titleColor: '#EEF2FF',
        bodyColor: '#8892B0',
        padding: 10,
        callbacks: {
          footer: function(items) {
            var t = 0;
            for (var i = 0; i < items.length; i++) { t += items[i].parsed.y; }
            return 'Total: €' + t + 'k ARR';
          }
        }
      };

      var scaleOpts = function(max) {
        return {
          x: { stacked: true, grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4A5578', font: { size: 10 } } },
          y: { stacked: true, max: max, grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#4A5578', font: { size: 10 },
               callback: function(v) { return '€' + v + 'k'; } } }
        };
      };

      var legendOpts = {
        position: 'bottom',
        labels: { color: '#8892B0', font: { size: 10 }, boxWidth: 10, padding: 10 }
      };

      // Chart 1 — Phase 1: €50k → €150k
      var c1 = document.getElementById('chart1');
      if (c1) {
        new Chart(c1, {
          type: 'bar',
          data: {
            labels: ['M1','M2','M3','M4','M5','M6','M7','M8','M9','M10','M11','M12'],
            datasets: [
              { label: 'Guided Buying',          data: [50,50,50,50,50,50,50,50,50,50,50,50],    backgroundColor: 'rgba(74,143,255,0.75)' },
              { label: 'Operational Automation', data: [0,0,0,0,40,40,40,40,40,40,40,40],        backgroundColor: 'rgba(124,92,252,0.75)' },
              { label: 'AI Negotiation',         data: [0,0,0,0,0,0,0,60,60,60,60,60],           backgroundColor: 'rgba(16,212,142,0.75)' }
            ]
          },
          options: { responsive: true, maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: { legend: legendOpts, tooltip: tooltipOpts },
            scales: scaleOpts(180)
          }
        });
      }

      // Chart 2 — Phase 2: €150k → €500k (distinct color palette)
      var c2 = document.getElementById('chart2');
      if (c2) {
        new Chart(c2, {
          type: 'bar',
          data: {
            labels: ['M12','M15','M18','M21','M24','M27','M30','M33','M36'],
            datasets: [
              { label: 'Phase 1 ARR (existing)',  data: [150,150,150,150,150,150,150,150,150], backgroundColor: 'rgba(100,120,180,0.3)' },
              { label: 'Strategic Intelligence',  data: [0,100,100,100,100,100,100,100,100],  backgroundColor: 'rgba(255,140,66,0.8)' },
              { label: 'NA Full Rollout',          data: [0,0,0,120,120,120,120,120,120],      backgroundColor: 'rgba(0,210,200,0.8)' },
              { label: 'Global + Enterprise',      data: [0,0,0,0,0,0,130,130,130],            backgroundColor: 'rgba(245,200,66,0.85)' }
            ]
          },
          options: { responsive: true, maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: { legend: legendOpts, tooltip: tooltipOpts },
            scales: scaleOpts(580)
          }
        });
      }
    }
    tryInit();
  });
  </script>
