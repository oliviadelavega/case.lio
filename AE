  <!DOCTYPE html>                                                                                                                                                                                              
  <html lang="en">
  <head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Lio - AE Case Interview Olivia</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --bg:#05081A;--card:#0B0F24;--el:#101530;
    --bdr:rgba(74,143,255,.12);--bdrg:rgba(74,143,255,.3);
    --blue:#4A8FFF;--bluel:#7AB3FF;--purple:#7C5CFC;--purplel:#A98DFF;
    --green:#10D48E;--orange:#FF8C42;--red:#FF4D6A;--gold:#F5C842;
    --text:#EEF2FF;--sub:#8892B0;--muted:#4A5578;
  }
  html{scroll-behavior:smooth}
  body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}

  /* ── NAV ── */
  nav{position:fixed;top:0;left:0;right:0;z-index:200;height:52px;
    background:rgba(5,8,26,.94);backdrop-filter:blur(18px);border-bottom:1px solid var(--bdr)}
  .nav-in{max-width:1120px;margin:0 auto;padding:0 24px;height:100%;display:flex;align-items:center;justify-content:space-between}
  .nav-logo{font-weight:900;font-size:.88rem;background:linear-gradient(135deg,var(--blue),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .nav-links{display:flex;gap:2px;list-style:none}
  .nav-links a{color:var(--sub);text-decoration:none;font-size:.7rem;font-weight:600;padding:5px 10px;border-radius:7px;transition:all .18s}
  .nav-links a:hover{color:var(--text);background:var(--el)}

  /* ── PAGE TITLE ── */
  .page-title{text-align:center;padding:96px 24px 60px;
    background:radial-gradient(ellipse 70% 50% at 50% 0%,rgba(74,143,255,.07),transparent)}
  .page-title h1{font-size:clamp(1.9rem,4vw,3.2rem);font-weight:900;letter-spacing:-.04em;
    background:linear-gradient(135deg,var(--text) 40%,var(--bluel));
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:10px}
  .page-title p{color:var(--sub);font-size:.95rem;max-width:440px;margin:0 auto}

  /* ── LAYOUT ── */
  .wrap{max-width:1120px;margin:0 auto;padding:0 24px}
  .sec{padding:64px 0;border-top:1px solid var(--bdr)}

  /* ── TYPE ── */
  .lbl{display:inline-flex;align-items:center;gap:6px;font-size:.62rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--blue);margin-bottom:10px}
  .dot{width:5px;height:5px;border-radius:50%;background:var(--blue);display:inline-block}
  h2{font-size:clamp(1.25rem,2.2vw,1.8rem);font-weight:800;letter-spacing:-.03em;line-height:1.15;margin-bottom:6px}
  h3{font-size:1rem;font-weight:700;letter-spacing:-.02em}
  .sec-sub{color:var(--sub);font-size:.875rem;max-width:520px;margin-bottom:32px}
  p{color:var(--sub);font-size:.875rem}

  /* ── TAGS ── */
  .tag{display:inline-block;font-size:.63rem;font-weight:600;padding:2px 8px;border-radius:5px;margin:2px 2px 0 0}
  .tb{background:rgba(74,143,255,.1);color:var(--bluel)}
  .tp{background:rgba(124,92,252,.1);color:var(--purplel)}
  .tg{background:rgba(16,212,142,.1);color:var(--green)}
  .to{background:rgba(255,140,66,.1);color:var(--orange)}
  .tr{background:rgba(255,77,106,.1);color:var(--red)}
  .tgold{background:rgba(245,200,66,.1);color:var(--gold)}

  /* ══════ SECTION 01 — ICP ══════ */
  .icp-intro{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:28px;align-items:start}
  @media(max-width:700px){.icp-intro{grid-template-columns:1fr}}
  .icp-intro-text{padding:20px 24px;background:var(--card);border:1px solid var(--bdr);border-radius:14px}
  .icp-intro-text h3{margin-bottom:10px;font-size:.98rem}
  .icp-intro-text p{font-size:.8rem;line-height:1.65}
  .icp-who{padding:20px 24px;background:linear-gradient(135deg,rgba(74,143,255,.06),rgba(124,92,252,.06));
    border:1px solid rgba(74,143,255,.2);border-radius:14px;position:relative;overflow:hidden}
  .icp-who::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--blue),var(--purple))}
  .icp-who h3{margin-bottom:12px;font-size:.98rem}
  .who-row{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05);align-items:flex-start}
  .who-row:last-child{border-bottom:none}
  .who-k{font-size:.68rem;font-weight:700;color:var(--muted);min-width:90px;padding-top:2px;flex-shrink:0}
  .who-v{font-size:.79rem;color:var(--text);line-height:1.5}

  /* 5 persona cards */
  .persona-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:32px}
  @media(max-width:900px){.persona-grid{grid-template-columns:repeat(3,1fr)}}
  @media(max-width:580px){.persona-grid{grid-template-columns:1fr 1fr}}
  .persona-card{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:18px;
    transition:all .2s;position:relative;overflow:hidden}
  .persona-card:hover{border-color:var(--bdrg);transform:translateY(-2px);box-shadow:0 6px 28px rgba(74,143,255,.07)}
  .persona-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
  .pc-role::before{background:var(--blue)}
  .pc-org::before{background:var(--purple)}
  .pc-pain::before{background:var(--red)}
  .pc-mot::before{background:var(--green)}
  .pc-demo::before{background:var(--orange)}
  .pc-icon{font-size:1.4rem;margin-bottom:10px;display:block}
  .pc-title{font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px}
  .pc-role .pc-title{color:var(--blue)}
  .pc-org .pc-title{color:var(--purplel)}
  .pc-pain .pc-title{color:var(--red)}
  .pc-mot .pc-title{color:var(--green)}
  .pc-demo .pc-title{color:var(--orange)}
  .pc-list{list-style:none;display:flex;flex-direction:column;gap:5px}
  .pc-list li{font-size:.73rem;color:var(--sub);display:flex;gap:5px;align-items:flex-start;line-height:1.4}
  .pc-list li::before{content:'·';color:var(--muted);flex-shrink:0;font-weight:700}

  /* Arrow + GM target */
  .icp-target-layout{display:grid;grid-template-columns:1fr 52px 1.3fr;gap:0;align-items:center;margin-bottom:36px}
  @media(max-width:720px){.icp-target-layout{grid-template-columns:1fr;gap:16px}}
  .icp-general-summary{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:22px}
  .icp-general-summary h4{font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);margin-bottom:14px}
  .ig-row{display:flex;gap:9px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.04);align-items:flex-start}
  .ig-row:last-child{border-bottom:none}
  .ig-k{font-size:.68rem;font-weight:600;color:var(--muted);min-width:88px;flex-shrink:0;padding-top:1px}
  .ig-v{font-size:.78rem;color:var(--text);line-height:1.5}
  .arr-col{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:0 6px}
  .arr-line{width:2px;height:32px;background:linear-gradient(180deg,var(--blue),var(--purple))}
  .arr-head{width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:10px solid var(--purple)}
  .arr-txt{font-size:.52rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);white-space:nowrap}
  @media(max-width:720px){.arr-col{display:none}}
  .gm-box{background:linear-gradient(135deg,rgba(74,143,255,.05),rgba(124,92,252,.05));
    border:1px solid rgba(74,143,255,.22);border-radius:14px;padding:22px;position:relative;overflow:hidden}
  .gm-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--blue),var(--purple))}
  .gm-head{display:flex;align-items:center;gap:12px;margin-bottom:16px}
  .gm-logo{width:40px;height:40px;background:#0f1f3d;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.58rem;font-weight:900;color:#5B9BD5;flex-shrink:0}
  .gm-head h3{margin-bottom:1px}.gm-sub{font-size:.72rem;color:var(--sub)}
  .gm-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
  .gs{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.05);border-radius:7px;padding:8px 10px}
  .gs .gv{font-size:.95rem;font-weight:800;color:var(--bluel);letter-spacing:-.02em}
  .gs .gl{font-size:.57rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-top:1px}
  .signal{display:flex;gap:6px;font-size:.73rem;color:var(--sub);padding:6px 8px;
    background:rgba(16,212,142,.05);border:1px solid rgba(16,212,142,.1);border-radius:6px;margin-bottom:5px;align-items:flex-start}
  .signal::before{content:'▸';color:var(--green);flex-shrink:0;margin-top:1px;font-size:.72rem}

  /* Champion */
  .champion-card{background:var(--card);border:2px solid var(--gold);border-radius:16px;overflow:hidden;box-shadow:0 0 36px rgba(245,200,66,.07);margin-bottom:20px}
  .ch-head{background:linear-gradient(135deg,rgba(245,200,66,.07),rgba(74,143,255,.05));
    border-bottom:1px solid rgba(245,200,66,.14);padding:20px 24px;display:flex;gap:14px;align-items:center;flex-wrap:wrap}
  .ch-av{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#2a4a7a,#142040);
    display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:900;color:#6AABFF;
    border:2px solid var(--gold);flex-shrink:0}
  .ch-name{font-size:1rem;font-weight:800;margin-bottom:1px}
  .ch-role{font-size:.75rem;color:var(--sub)}.ch-co{font-size:.7rem;color:var(--bluel);font-weight:600;margin-top:1px}
  .ch-badge{margin-left:auto;background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.22);
    color:var(--gold);font-size:.62rem;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.07em}
  .ch-body{padding:22px 24px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
  @media(max-width:720px){.ch-body{grid-template-columns:1fr}}
  .ch-sec h5{font-size:.58rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:9px}
  .chal{display:flex;gap:8px;padding:8px 10px;background:rgba(255,77,106,.05);border:1px solid rgba(255,77,106,.1);border-radius:8px;margin-bottom:7px}
  .cnum{font-size:.62rem;font-weight:800;color:var(--red);background:rgba(255,77,106,.1);
    width:17px;height:17px;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
  .cprob{font-size:.73rem;font-weight:600;color:var(--text);margin-bottom:2px}
  .chelp{font-size:.68rem;color:var(--green)}
  .why-item{padding:8px 10px;border-radius:8px;margin-bottom:6px}
  .wy-b{background:rgba(74,143,255,.05);border:1px solid rgba(74,143,255,.12)}
  .wy-p{background:rgba(124,92,252,.05);border:1px solid rgba(124,92,252,.12)}
  .wy-n{background:rgba(245,200,66,.05);border:1px solid rgba(245,200,66,.12)}
  .wlabel{font-size:.57rem;font-weight:800;text-transform:uppercase;letter-spacing:.1em;margin-bottom:2px}
  .wy-b .wlabel{color:var(--blue)}.wy-p .wlabel{color:var(--purplel)}.wy-n .wlabel{color:var(--gold)}
  .wtext{font-size:.73rem;color:var(--sub);line-height:1.5}
  .irow{display:flex;gap:9px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.04);align-items:flex-start}
  .irow:last-child{border-bottom:none}
  .ik{font-size:.68rem;font-weight:600;color:var(--muted);min-width:72px;flex-shrink:0;padding-top:1px}
  .iv{font-size:.75rem;color:var(--text);line-height:1.5}
  .quote-box{margin-top:10px;padding:8px 11px;background:rgba(245,200,66,.04);border:1px solid rgba(245,200,66,.12);border-radius:8px;font-size:.7rem;color:var(--sub);font-style:italic;line-height:1.55}

  /* Methodology note */
  .methodology{background:var(--card);border:1px solid var(--bdr);border-radius:12px;padding:18px 22px;display:flex;gap:16px;align-items:flex-start}
  .meth-icon{font-size:1.3rem;flex-shrink:0;margin-top:2px}
  .meth-text h5{font-size:.78rem;font-weight:700;margin-bottom:6px}
  .meth-text p{font-size:.76rem;line-height:1.6}
  .meth-tags{margin-top:10px}

  /* ══════ SECTION 02 — OUTREACH ══════ */
  .email-wrap{background:#0C0F22;border:1px solid var(--bdr);border-radius:16px;overflow:hidden;box-shadow:0 8px 48px rgba(0,0,0,.5)}
  .echrome{background:#080B1C;border-bottom:1px solid var(--bdr);padding:10px 18px;display:flex;align-items:center;gap:8px}
  .edots{display:flex;gap:5px}.ed{width:9px;height:9px;border-radius:50%}
  .ed-r{background:#FF5F57}.ed-y{background:#FFBD2E}.ed-g{background:#28C840}
  .ecompose{padding:22px 28px}
  .ef{display:flex;gap:12px;padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)}
  .ek{font-size:.63rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);min-width:50px;padding-top:2px;flex-shrink:0}
  .ev{font-size:.8rem;color:var(--text)}.ev .hl{color:var(--bluel);font-weight:600}
  .esubj{font-size:1rem;font-weight:800}
  .ebody{padding:20px 0 0 62px;font-size:.86rem;line-height:1.85}
  .ebody p{color:var(--sub);margin-bottom:12px}.hook{color:var(--text);font-weight:600}
  .stat-box{display:inline-flex;align-items:center;gap:6px;background:rgba(16,212,142,.07);border:1px solid rgba(16,212,142,.18);
    border-radius:8px;padding:7px 12px;color:var(--green);font-weight:600;font-size:.78rem;margin-bottom:12px}
  .cta-btn{display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,var(--blue),var(--purple));
    color:#fff;font-size:.77rem;font-weight:700;padding:8px 16px;border-radius:8px;text-decoration:none;margin-top:4px}
  .esig{border-top:1px solid rgba(255,255,255,.05);margin-top:16px;padding-top:12px}
  .esig-name{font-weight:800;color:var(--text);font-size:.86rem}
  .esig-sub,.esig-co{font-size:.69rem;color:var(--muted)}.esig-co{color:var(--bluel);font-weight:600}
  .annot-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:16px}
  @media(max-width:640px){.annot-row{grid-template-columns:1fr}}
  .annot{padding:12px 14px;background:rgba(74,143,255,.04);border:1px solid rgba(74,143,255,.1);border-left:3px solid var(--blue);border-radius:0 8px 8px 0}
  .annot.purple{background:rgba(124,92,252,.04);border-color:rgba(124,92,252,.1);border-left-color:var(--purple)}
  .annot.green{background:rgba(16,212,142,.04);border-color:rgba(16,212,142,.1);border-left-color:var(--green)}
  .annot-ttl{font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:3px}
  .annot .annot-ttl{color:var(--blue)}.annot.purple .annot-ttl{color:var(--purplel)}.annot.green .annot-ttl{color:var(--green)}
  .annot p{font-size:.72rem}

  /* ══════ SECTION 03 — DEAL ══════ */
  .pipeline-lbl{font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--blue);margin-bottom:12px;display:block}
  .tabs{display:flex;overflow-x:auto;border:1px solid var(--bdr);border-radius:12px 12px 0 0;border-bottom:none}
  .tab{flex:1;min-width:88px;padding:11px 8px;text-align:center;cursor:pointer;
    background:var(--card);border-right:1px solid var(--bdr);transition:all .18s;user-select:none}
  .tab:first-child{border-radius:11px 0 0 0}.tab:last-child{border-right:none;border-radius:0 11px 0 0}
  .tab:hover{background:var(--el)}
  .tab.active{background:rgba(74,143,255,.09);border-bottom:2px solid var(--blue)}
  .tab-num{font-size:.56rem;font-weight:700;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px}
  .tab-name{font-size:.7rem;font-weight:700;color:var(--text)}
  .tab-wk{font-size:.6rem;color:var(--muted);margin-top:1px}
  .tab.active .tab-name{color:var(--bluel)}
  .panel-wrap{background:var(--card);border:1px solid var(--bdr);border-radius:0 0 12px 12px;padding:22px;border-top:none;margin-bottom:48px}
  .sp-goal-lbl{font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:4px}
  .sp-goal{background:rgba(74,143,255,.07);border:1px solid rgba(74,143,255,.14);border-radius:8px;padding:9px 13px;font-size:.78rem;color:var(--bluel);margin-bottom:16px;line-height:1.5}
  .sp-cols{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:540px){.sp-cols{grid-template-columns:1fr}}
  .sp-col h5{font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}
  .sp-col ul{list-style:none;display:flex;flex-direction:column;gap:5px}
  .sp-col li{font-size:.75rem;color:var(--sub);display:flex;gap:6px;align-items:flex-start;line-height:1.5}
  .sp-col li::before{content:'→';color:var(--blue);font-size:.66rem;flex-shrink:0;margin-top:2px}

  /* Political map */
  .pm-champion{background:linear-gradient(135deg,rgba(245,200,66,.07),rgba(74,143,255,.05));
    border:2px solid var(--gold);border-radius:16px;padding:20px 22px;box-shadow:0 0 36px rgba(245,200,66,.07);margin-bottom:18px}
  .pm-badge{display:inline-block;background:rgba(245,200,66,.1);border:1px solid rgba(245,200,66,.22);color:var(--gold);font-size:.62rem;font-weight:700;padding:3px
  10px;border-radius:20px;letter-spacing:.07em;margin-bottom:10px}
  .pm-name{font-size:1rem;font-weight:800;margin-bottom:2px}
  .pm-role{font-size:.75rem;color:var(--sub)}.pm-co{font-size:.7rem;color:var(--bluel);font-weight:600;margin-top:1px}
  .pm-inner{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:14px}
  @media(max-width:580px){.pm-inner{grid-template-columns:1fr}}
  .pm-inner-col h6{font-size:.58rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
  .pm-inner-col.g h6{color:var(--green)}.pm-inner-col.r h6{color:var(--orange)}
  .pm-bullet{display:flex;gap:5px;font-size:.72rem;color:var(--sub);margin-bottom:5px;align-items:flex-start;line-height:1.45}
  .g .pm-bullet::before{content:'✓';color:var(--green);flex-shrink:0;font-size:.66rem;margin-top:2px}
  .r .pm-bullet::before{content:'⚡';color:var(--orange);flex-shrink:0;font-size:.66rem;margin-top:1px}
  .pm-action{font-size:.68rem;color:var(--blue);font-weight:600;margin-top:8px}
  .pm-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
  @media(max-width:700px){.pm-grid{grid-template-columns:1fr}}
  .pm-card{background:var(--card);border:1px solid var(--bdr);border-radius:13px;padding:16px;transition:all .2s}
  .pm-card:hover{border-color:var(--bdrg);transform:translateY(-2px)}
  .pm-card .pm-name{font-size:.88rem}.pm-card .pm-role{font-size:.7rem;margin-bottom:6px}
  .pm-role-badge{display:inline-block;font-size:.6rem;font-weight:700;padding:2px 8px;border-radius:5px;margin-bottom:10px}
  .pm-section{margin-bottom:8px}
  .pm-section h6{font-size:.57rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
  .pm-card .pm-action{display:block;margin-top:8px;font-size:.67rem;color:var(--blue);font-weight:600;
    padding-top:8px;border-top:1px solid rgba(255,255,255,.05)}

  /* ══════ SECTION 04 — EXPAND ══════ */
  .expand-charts{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:36px}
  @media(max-width:700px){.expand-charts{grid-template-columns:1fr}}
  .chart-box{background:var(--card);border:1px solid var(--bdr);border-radius:14px;padding:20px}
  .chart-box h4{font-size:.84rem;font-weight:700;margin-bottom:3px}
  .chart-box .chart-sub{font-size:.72rem;color:var(--sub);margin-bottom:14px}
